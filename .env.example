# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/portfolio_db

# ─── Admin credentials ─────────────────────────────────────────────────────────
# These are the username/password you use at /login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_use_strong_password

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173

# ─── Vite (frontend) ───────────────────────────────────────────────────────────
# Must start with VITE_ to be exposed to the browser bundle
VITE_API_URL=http://localhost:3001
